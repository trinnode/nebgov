# NebGov local development environment
# Copy to .env and adjust as needed.

# ── Core governance config ─────────────────────────────────────────────────────

# Governor contract address (required for indexer + app)
GOVERNOR_ADDRESS=

# Soroban RPC endpoint used by the indexer (testnet by default)
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Indexer polling interval (ms)
POLL_INTERVAL_MS=5000

# ── Database (Postgres) ────────────────────────────────────────────────────────

POSTGRES_DB=nebgov
POSTGRES_USER=nebgov
POSTGRES_PASSWORD=nebgov

# Optional: host port mapping for Postgres
POSTGRES_PORT=5432

# ── Backend API ────────────────────────────────────────────────────────────────

# JWT secret for backend auth (dev default is fine for local)
JWT_SECRET=dev-secret

# Optional: host port mapping for backend
BACKEND_PORT=3001

# ── Frontend (Next.js app) ─────────────────────────────────────────────────────

NEXT_PUBLIC_NETWORK=testnet

# Backend base URL as seen by the browser (host-side)
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Optional: host port mapping for app
APP_PORT=3000

# Optional: host port mapping for indexer
INDEXER_PORT=3002

# ============================================================
# NebGov — Environment Variables
# ============================================================
# Copy this file to .env.testnet and run scripts/deploy-testnet.sh
# to populate the contract addresses automatically.
# ============================================================

# ----- Stellar Identity -----
# Name of the stellar-cli identity used for deployment.
# The script creates and funds this identity if it does not exist.
STELLAR_IDENTITY=deployer

# Stellar network to deploy to
STELLAR_NETWORK=testnet

# Optional: Custom RPC URL (defaults to public testnet endpoint)
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# ----- SEP-41 Token (for token-votes wrapper) -----
# Address of an existing SEP-41 token on testnet.
# Leave empty to use the Stellar testnet native XLM asset.
SEP41_TOKEN_ADDRESS=

# ----- Deployed Contract Addresses -----
# These are populated automatically by scripts/deploy-testnet.sh.
TOKEN_VOTES_ADDRESS=
TIMELOCK_ADDRESS=
GOVERNOR_ADDRESS=
TREASURY_ADDRESS=
FACTORY_ADDRESS=

# ----- Governor Defaults -----
# Voting delay in ledgers (~5 sec each). Default: 60 (~5 min)
VOTING_DELAY=60
# Voting period in ledgers. Default: 17280 (~1 day)
VOTING_PERIOD=17280
# Quorum numerator (percentage). Default: 4 (4%)
QUORUM_NUMERATOR=4
# Minimum tokens to create a proposal. Default: 100000000 (10 with 7 decimals)
PROPOSAL_THRESHOLD=100000000

# ----- Timelock Defaults -----
# Minimum execution delay in seconds. Default: 3600 (1 hour)
TIMELOCK_MIN_DELAY=3600

# ----- Treasury Defaults -----
# Number of owner signatures required. Default: 1
TREASURY_THRESHOLD=1
